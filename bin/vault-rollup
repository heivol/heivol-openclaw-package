#!/usr/bin/env python3
"""Time-scoped rollup of diary + meta + sources.

    vault-rollup --week            # last 7 days  → meta/rollups/YYYY-WNN.md
    vault-rollup --month           # previous calendar month → YYYY-MM.md
    vault-rollup --year            # previous calendar year  → YYYY.md

Rollup contents:
  - window, counts (sessions, diary entries, sources ingested, corrections)
  - top entities (wiki-link frequency in diary + sources)
  - top tags (frontmatter aggregate)
  - LLM-written narrative (if llm_cmd available; silent fallback otherwise)

Output is written to $OPENCLAW_VAULT/meta/rollups/<scope>.md and also printed
to stdout.
"""
from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import re
import subprocess
import sys
from collections import Counter
from pathlib import Path

try:
    import frontmatter
except ImportError as e:
    print(f"vault-rollup: missing dependency ({e})", file=sys.stderr)
    sys.exit(1)

VAULT = Path(os.environ.get("OPENCLAW_VAULT", Path.home() / "vault")).expanduser()
ROOT = Path(os.environ.get("OPENCLAW_ROOT", Path.home() / ".openclaw")).expanduser()
LLM_BIN = ROOT / "runtime" / "bin" / "llm"
if not LLM_BIN.exists():
    LLM_BIN = Path(__file__).resolve().parent / "llm"

WIKI = re.compile(r"\[\[([^\]|#]+)(?:\|[^\]]+)?\]\]")


def window_for(scope: str, end: dt.date) -> tuple[dt.date, dt.date, str]:
    """Return (start_inclusive, end_inclusive, slug) for the chosen scope."""
    if scope == "week":
        start = end - dt.timedelta(days=6)
        iso = end.isocalendar()
        slug = f"{iso.year}-W{iso.week:02d}"
        return start, end, slug
    if scope == "month":
        prev = (end.replace(day=1) - dt.timedelta(days=1))
        start = prev.replace(day=1)
        slug = f"{prev.year}-{prev.month:02d}"
        return start, prev, slug
    if scope == "year":
        start = dt.date(end.year - 1, 1, 1)
        last = dt.date(end.year - 1, 12, 31)
        slug = f"{end.year - 1}"
        return start, last, slug
    raise ValueError(scope)


def in_window(d: dt.date, start: dt.date, end: dt.date) -> bool:
    return start <= d <= end


def collect_diary(start: dt.date, end: dt.date) -> list[tuple[dt.date, Path, str]]:
    diary_dir = VAULT / "diary"
    if not diary_dir.exists():
        return []
    out = []
    for f in sorted(diary_dir.glob("*.md")):
        try:
            d = dt.date.fromisoformat(f.stem)
        except ValueError:
            continue
        if not in_window(d, start, end):
            continue
        try:
            out.append((d, f, f.read_text(encoding="utf-8", errors="ignore")))
        except Exception:
            continue
    return out


def collect_sources(start: dt.date, end: dt.date) -> list[Path]:
    sources_dir = VAULT / "sources"
    if not sources_dir.exists():
        return []
    out = []
    for f in sorted(sources_dir.rglob("*.md")):
        try:
            post = frontmatter.load(f)
        except Exception:
            continue
        raw = str(post.metadata.get("ingested") or "")
        d = None
        try:
            d = dt.date.fromisoformat(raw[:10]) if raw else None
        except ValueError:
            pass
        if d is None:
            # fall back to mtime
            d = dt.date.fromtimestamp(f.stat().st_mtime)
        if in_window(d, start, end):
            out.append(f)
    return out


def collect_analyses(start: dt.date, end: dt.date) -> list[Path]:
    d = VAULT / "meta" / "analysis"
    if not d.exists():
        return []
    out = []
    for f in sorted(d.glob("*.md")):
        try:
            day = dt.date.fromisoformat(f.stem[:10])
        except ValueError:
            continue
        if in_window(day, start, end):
            out.append(f)
    return out


def aggregate_signals(start: dt.date, end: dt.date) -> dict:
    """Aggregate per-day signal totals from raw + compacted."""
    sigs_dir = VAULT / "meta" / "signals"
    compact_dir = VAULT / "meta" / "signals-compact"
    sessions = 0
    errors = 0
    corrections = 0
    duration = 0
    tool_usage: Counter = Counter()
    skill_usage: Counter = Counter()

    if sigs_dir.exists():
        for f in sigs_dir.glob("*.jsonl"):
            try:
                day = dt.date.fromisoformat(f.stem)
            except ValueError:
                continue
            if not in_window(day, start, end):
                continue
            for line in f.read_text(errors="ignore").splitlines():
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                sessions += 1
                errors += obj.get("errors", 0) or 0
                corrections += obj.get("corrections", 0) or 0
                duration += obj.get("duration_s", 0) or 0
                for t, n in (obj.get("tools") or {}).items():
                    tool_usage[t] += n
                for s in obj.get("skills") or []:
                    skill_usage[s] += 1

    # Compacted files are JSONL but one record per day (see weekly.sh)
    if compact_dir.exists():
        for f in compact_dir.glob("*.jsonl"):
            for line in f.read_text(errors="ignore").splitlines():
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                try:
                    day = dt.date.fromisoformat(obj.get("date", "")[:10])
                except ValueError:
                    continue
                if not in_window(day, start, end):
                    continue
                sessions += obj.get("sessions", 0) or 0
                errors += obj.get("errors", 0) or 0
                corrections += obj.get("corrections", 0) or 0
                duration += obj.get("duration_s_total", 0) or 0

    return {
        "sessions": sessions,
        "errors": errors,
        "corrections": corrections,
        "duration_s": duration,
        "top_tools": tool_usage.most_common(10),
        "top_skills": skill_usage.most_common(10),
    }


def extract_entities(texts: list[str]) -> Counter:
    c: Counter = Counter()
    for t in texts:
        for m in WIKI.finditer(t):
            name = m.group(1).strip().split("/")[-1]
            if name.endswith(".md"):
                name = name[:-3]
            c[name] += 1
    return c


def extract_tags(paths: list[Path]) -> Counter:
    c: Counter = Counter()
    for p in paths:
        try:
            post = frontmatter.load(p)
        except Exception:
            continue
        tags = post.metadata.get("tags") or []
        if not isinstance(tags, list):
            tags = [tags]
        for t in tags:
            c[str(t).lower()] += 1
    return c


def llm_narrative(scope: str, window: tuple[dt.date, dt.date], agg: dict, entities: Counter, tags: Counter, diary_count: int, sources_count: int) -> str:
    prompt = f"""\
You are writing a {scope}-level narrative for a personal knowledge base. Window: {window[0].isoformat()} to {window[1].isoformat()}.

Metrics:
- Diary entries: {diary_count}
- Sources ingested: {sources_count}
- Sessions: {agg.get('sessions', 0)}
- Top entities: {[e for e, _ in entities.most_common(8)]}
- Top tags: {[t for t, _ in tags.most_common(8)]}

Write 3–5 sentences of observation: themes, shifts, notable threads. No bullet points. No intro or conclusion."""
    try:
        r = subprocess.run([str(LLM_BIN)], input=prompt, text=True, capture_output=True, timeout=90)
        if r.returncode == 0:
            return r.stdout.strip()
    except Exception:
        pass
    return ""


def format_rollup(scope: str, slug: str, window: tuple[dt.date, dt.date],
                  diary_count: int, sources_count: int, analyses_count: int,
                  agg: dict, entities: Counter, tags: Counter, narrative: str) -> str:
    lines = [
        "---",
        f"type: rollup",
        f"scope: {scope}",
        f"slug: {slug}",
        f"window_start: {window[0].isoformat()}",
        f"window_end: {window[1].isoformat()}",
        "schema: 1",
        "---",
        "",
        f"# {scope.capitalize()} Rollup — {slug}",
        "",
        f"_{window[0].isoformat()} → {window[1].isoformat()}_",
        "",
        "## Counts",
        "",
        f"- Diary entries: **{diary_count}**",
        f"- Sources ingested: **{sources_count}**",
        f"- Daily analyses: **{analyses_count}**",
        f"- Sessions: **{agg['sessions']}**",
        f"- User corrections: **{agg['corrections']}**",
        f"- Errors: **{agg['errors']}**",
        f"- Total duration: **{agg['duration_s'] // 60} min**",
        "",
        "## Top entities",
        "",
    ]
    if entities:
        for name, n in entities.most_common(10):
            lines.append(f"- [[entities/{name}]] — {n}")
    else:
        lines.append("_None referenced._")

    lines += ["", "## Top tags", ""]
    if tags:
        for t, n in tags.most_common(10):
            lines.append(f"- `{t}` — {n}")
    else:
        lines.append("_None._")

    if agg["top_tools"]:
        lines += ["", "## Top tools", ""]
        for t, n in agg["top_tools"]:
            lines.append(f"- `{t}` — {n}")

    if agg["top_skills"]:
        lines += ["", "## Top skills", ""]
        for s, n in agg["top_skills"]:
            lines.append(f"- `{s}` — {n}")

    if narrative:
        lines += ["", "## Narrative", "", narrative]

    return "\n".join(lines).rstrip() + "\n"


def main() -> int:
    ap = argparse.ArgumentParser(description="Time-scoped rollup")
    g = ap.add_mutually_exclusive_group(required=True)
    g.add_argument("--week", action="store_true")
    g.add_argument("--month", action="store_true")
    g.add_argument("--year", action="store_true")
    ap.add_argument("--end-date", help="Override the anchor date (default today)")
    ap.add_argument("--no-llm", action="store_true")
    args = ap.parse_args()

    end = dt.date.fromisoformat(args.end_date) if args.end_date else dt.date.today()
    scope = "week" if args.week else ("month" if args.month else "year")
    window = window_for(scope, end)
    start, stop, slug = window

    diary = collect_diary(start, stop)
    sources = collect_sources(start, stop)
    analyses = collect_analyses(start, stop)
    agg = aggregate_signals(start, stop)
    entities = extract_entities([body for _, _, body in diary] + [p.read_text(errors="ignore") for p in sources])
    tags = extract_tags([p for _, p, _ in diary] + sources + analyses)

    narrative = ""
    if not args.no_llm and (diary or sources or agg["sessions"]):
        narrative = llm_narrative(scope, (start, stop), agg, entities, tags, len(diary), len(sources))

    report = format_rollup(scope, slug, (start, stop), len(diary), len(sources), len(analyses), agg, entities, tags, narrative)

    out_dir = VAULT / "meta" / "rollups"
    out_dir.mkdir(parents=True, exist_ok=True)
    out = out_dir / f"{slug}.md"
    out.write_text(report, encoding="utf-8")
    print(f"wrote {out.relative_to(VAULT)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
